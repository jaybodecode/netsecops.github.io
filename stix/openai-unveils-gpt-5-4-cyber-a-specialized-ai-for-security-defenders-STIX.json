            "name": "CyberNetSec.io",
            "description": "CyberNetSec.io is a cybersecurity intelligence platform providing timely, accurate, deduplicated, and actionable threat intelligence for security professionals. The platform aggregates, deduplicates, and enriches threat data from diverse public sources, mapping all threats to MITRE ATT&CK and D3FEND frameworks with operationally-focused analysis, detection guidance, and mitigation recommendations. Operated by security professionals, for the security community.",
            "identity_class": "organization",
            "sectors": [
                "technology"
            ],
