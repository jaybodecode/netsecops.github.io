            "name": "Multiple Failed Logon Attempts",
            "description": "Detects a high volume of failed logon attempts (Event ID 4625), which could be indicative of a brute-force attempt.",
            "indicator_types": [
                "anomalous-activity"
            ],
            "pattern": "title: Multiple Failed Logon Attempts\nid: 12345678-abcd-4ef0-9876-54321fedcba0\nstatus: experimental\ndescription: Detects a high volume of failed logon attempts (Event ID 4625), which could indicate a brute-force attack.\nreferences:\n  - https://classactionu.org/current-data-breaches/sandhills-medical-foundation-2/\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1110\n  - attack.credential_access\nlevel: medium\nlogsource:\n  product: windows\n  service: security\ndetection:\n  selection:\n    EventID: 4625\n  condition: selection | count() > 20",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:04.7832Z"
        },
