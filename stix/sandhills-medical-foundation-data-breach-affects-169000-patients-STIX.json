        },
        {
            "type": "indicator",
            "spec_version": "2.1",
            "id": "indicator--64c5ea07-3612-55d2-b935-1b251fafd485",
            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
            "created": "2026-06-04T15:02:05.068739Z",
            "modified": "2026-06-04T15:02:05.068739Z",
            "name": "VSSAdmin Shadow Copy Deletion",
            "description": "Detects the use of vssadmin.exe to delete volume shadow copies, a technique commonly used by ransomware to prevent system recovery.",
            "indicator_types": [
                "malicious-activity"
            ],
            "pattern": "title: VSSAdmin Shadow Copy Deletion\nid: 5e8b1c4a-7d3f-4e9a-8b1c-4d7e8f9a0b1c\nstatus: experimental\ndescription: Detects the use of vssadmin.exe to delete volume shadow copies, a common ransomware TTP to inhibit system recovery.\nreferences:\n  - https://classactionu.org/current-data-breaches/sandhills-medical-foundation-2/\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1490\n  - attack.impact\nlevel: high\nlogsource:\n  category: process_creation\n  product: windows\ndetection:\n  selection:\n    Image|endswith: '\\vssadmin.exe'\n    CommandLine|contains:\n      - 'delete'\n      - 'shadows'\n  condition: selection",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:04.7832Z"
        },
        {
            "type": "indicator",
            "spec_version": "2.1",
            "id": "indicator--a8c10b71-0de6-5137-ae8b-567a52019639",
            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
            "created": "2026-06-04T15:02:05.072329Z",
            "modified": "2026-06-04T15:02:05.072329Z",
            "name": "PowerShell Encoded Command Execution",
            "description": "Detects PowerShell execution with encoded commands, a common technique for obfuscating malicious activity.",
            "indicator_types": [
                "malicious-activity"
            ],
            "pattern": "title: PowerShell Encoded Command Execution\nid: a1b2c3d4-e5f6-4a90-8bcd-ef1234567890\nstatus: experimental\ndescription: Detects the use of PowerShell with encoded commands, often used by attackers for obfuscation during lateral movement and reconnaissance.\nreferences:\n  - https://classactionu.org/current-data-breaches/sandhills-medical-foundation-2/\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1059.001\n  - attack.execution\nlevel: medium\nlogsource:\n  category: process_creation\n  product: windows\ndetection:\n  selection:\n    Image|endswith: '\\powershell.exe'\n    CommandLine|contains:\n      - ' -enc '\n      - ' -encodedcommand '\n      - ' -e '\n  condition: selection",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:04.7832Z"
        },
        {
            "type": "indicator",
            "spec_version": "2.1",
            "id": "indicator--22c5b420-accc-5a6d-940c-54c3e68b97e4",
            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
            "created": "2026-06-04T15:02:05.075526Z",
            "modified": "2026-06-04T15:02:05.075526Z",
            "name": "Anomalous Outbound Data Transfer",
            "description": "Detects large, unexpected data uploads to cloud storage services, which can be a sign of data exfiltration before ransomware deployment.",
            "indicator_types": [
                "anomalous-activity"
            ],
            "pattern": "title: Anomalous Outbound Data Transfer to Cloud Storage\nid: b678c477-e7ed-480a-a01d-1c9ab08c113c\nstatus: experimental\ndescription: Detects potentially large outbound data transfers to common cloud storage services, which could indicate data exfiltration prior to a ransomware attack.\nreferences:\n  - https://classactionu.org/current-data-breaches/sandhills-medical-foundation-2/\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1048\n  - attack.exfiltration\nlevel: medium\nlogsource:\n  category: proxy\ndetection:\n  selection:\n    cs-host|contains:\n      - 'mega.nz'\n      - 'dropbox.com'\n      - 'drive.google.com'\n  condition: selection",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:04.7832Z"
        },
        {
            "type": "indicator",
            "spec_version": "2.1",
            "id": "indicator--d5a59cdf-eb59-51af-b3cc-f41a12f8a9c4",
            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
            "created": "2026-06-04T15:02:05.079087Z",
