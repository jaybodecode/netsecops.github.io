            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
            "created": "2026-06-04T15:02:14.777723Z",
            "modified": "2026-06-04T15:02:14.777723Z",
            "name": "Akira Remote Access Tool Execution",
            "description": "Detects the execution of remote access tools such as PsExec, AnyDesk, and RustDesk, which Akira has been observed using for lateral movement.",
            "indicator_types": [
                "malicious-activity"
            ],
            "pattern": "title: Akira Remote Access Tool Execution\nid: 42817613-ea5a-4134-b912-17acdea26792\nstatus: experimental\ndescription: Detects the execution of legitimate remote access tools like PsExec, AnyDesk, and RustDesk, which are known to be used by the Akira ransomware group for lateral movement.\nreferences:\n  - https://www.claimdepot.com/data-breach/medenet-2026\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1021.002\n  - attack.lateral_movement\nlevel: medium\nlogsource:\n  category: process_creation\n  product: windows\ndetection:\n  selection:\n    Image|endswith:\n      - '\\psexec.exe'\n      - '\\anydesk.exe'\n      - '\\rustdesk.exe'\n  condition: selection",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:14.394152Z"
        },
