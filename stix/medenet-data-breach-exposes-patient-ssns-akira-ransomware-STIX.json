        {
            "type": "indicator",
            "spec_version": "2.1",
            "id": "indicator--7ecdb213-a2a3-5c4c-838e-bb28953df5c0",
            "created_by_ref": "identity--f165d4a1-7c3b-4e9f-b2d8-6a5e8c2f1b9d",
