            "modified": "2026-06-04T15:02:14.774118Z",
            "name": "Akira Ransomware Volume Shadow Copy Deletion",
            "description": "Detects the execution of 'vssadmin.exe' to delete all volume shadow copies, a common technique used by ransomware like Akira to prevent recovery.",
            "indicator_types": [
                "malicious-activity"
            ],
            "pattern": "title: Akira Ransomware Volume Shadow Copy Deletion\nid: 2b9c1d8e-4f5a-4b6c-8d9e-0f1a2b3c4d5e\nstatus: experimental\ndescription: Detects the command used by Akira ransomware to delete volume shadow copies, inhibiting system recovery.\nreferences:\n  - https://www.claimdepot.com/data-breach/medenet-2026\nauthor: cyber.netsecops.io\ndate: 2026-06-04\ntags:\n  - attack.t1490\n  - attack.impact\nlevel: high\nlogsource:\n  category: process_creation\n  product: windows\ndetection:\n  selection:\n    Image|endswith: '\\vssadmin.exe'\n    CommandLine|contains|all:\n      - 'delete'\n      - 'shadows'\n      - '/all'\n      - '/quiet'\n  condition: selection",
            "pattern_type": "sigma",
            "valid_from": "2026-06-04T15:02:14.394152Z"
        },
        {
            "type": "indicator",
            "spec_version": "2.1",
